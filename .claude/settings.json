{
  "env": {
    "RUST_LOG": "debug",
    "RUST_BACKTRACE": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allowRules": [
      "Bash(cargo *)",
      "Bash(rustup *)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git status*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git fetch*)",
      "Bash(git checkout*)",
      "Bash(git branch*)",
      "Bash(mkdir *)",
      "Bash(chmod *)"
    ],
    "denyRules": [
      "Bash(sudo rm*)"
    ]
  }
}
